# ==================== AgeGate as a Service .env.example ====================
PORT=8080
LOG_LEVEL=info
PUBLIC_URL=http://agegate.local
ADMIN_USER=admin
ADMIN_PASS=change-me-in-production-please!
TIMESCALEDB_HOST=timescaledb
TIMESCALEDB_PORT=5432
TIMESCALEDB_DB=agegate
TIMESCALEDB_USER=postgres
TIMESCALEDB_PASSWORD=your-timescaledb-password
REDIS_HOST=redis
REDIS_PORT=6379
VERIFIER_BACKEND=mock
ALLOWED_ORIGINS=http://agegate.local,https://yourdomain.it

# ========== PRIVACY & ANONYMIZATION ==========
# Enable IP hashing (double anonymity) - EU Blueprint compliance
ANONYMIZE_IP=true

# Secret salt for IP hashing (auto-generated if not set)
# WARNING: Keep this secret! Rotate daily in production
IP_SALT=

NODE_ENV=production

# Data retention (days) for TimescaleDB, default 30
RETENTION_DAYS=30

# Email (for self‑onboarding)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
FROM_EMAIL=noreply@agegate.local

# Stripe (for subscription billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly
