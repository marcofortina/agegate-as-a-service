{
  "name": "agegate-verifier",
  "version": "0.3.0",
  "main": "server.js",
  "scripts": {
    "start": "node -r ./tracing.js server.js",
    "dev": "nodemon server.js",
    "lint": "eslint . --ext .js --fix",
    "lint:check": "eslint . --ext .js",
    "test": "NODE_ENV=test jest --coverage --silent",
    "test:watch": "jest --watch",
    "test:integration": "jest --config jest.integration.config.js --detectOpenHandles --forceExit",
    "test:integration-compose": "jest --config jest.integration.config.js --testPathPattern=compose.test.js --detectOpenHandles --forceExit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "0.54.0",
    "@opentelemetry/exporter-metrics-otlp-http": "0.54.2",
    "@opentelemetry/exporter-trace-otlp-http": "0.54.2",
    "@opentelemetry/resources": "^1.29.0",
    "@opentelemetry/sdk-metrics": "^1.29.0",
    "@opentelemetry/sdk-node": "0.54.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-session": "^1.19.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.15.0",
    "pg": "^8.13.0",
    "pino": "^9.6.0",
    "prom-client": "^15.1.3",
    "stripe": "^18.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-jest": "^28.11.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "supertest": "^7.1.0",
    "wait-on": "^9.0.4"
  }
}
